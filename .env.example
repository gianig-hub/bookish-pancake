# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="EK Marketplace"
NEXT_PUBLIC_APP_ENV=development

# API
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database (PostgreSQL)
# Used by apps/api via Prisma
DATABASE_URL=postgresql://ekuser:ekpassword@localhost:5432/ekmarketplace

# Redis
# Used by apps/api (rate limiting, caching) and apps/worker (job queue)
REDIS_URL=redis://localhost:6379

# Authentication / Session
# Generate secure random values for production: openssl rand -base64 32
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production

# Email
# Provider: Resend, SendGrid, AWS SES, etc.
EMAIL_FROM=noreply@ekmarketplace.co.uk
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_placeholder

# Storage (Object Storage for user-uploaded images)
# Provider: AWS S3, Cloudflare R2, OVH Object Storage
STORAGE_PROVIDER=s3
STORAGE_BUCKET=ekmarketplace-uploads
STORAGE_REGION=eu-west-2
STORAGE_ACCESS_KEY_ID=placeholder
STORAGE_SECRET_ACCESS_KEY=placeholder
STORAGE_ENDPOINT=https://s3.eu-west-2.amazonaws.com
NEXT_PUBLIC_STORAGE_CDN_URL=https://cdn.ekmarketplace.co.uk

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# AI / OpenAI
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000

# Logging
LOG_LEVEL=info
# SENTRY_DSN=https://placeholder@sentry.io/placeholder

# Feature Flags
# Set to 'true' to enable, 'false' or omit to disable
FEATURE_AI_LISTING_ASSISTANT=false
FEATURE_AI_SEARCH=false
FEATURE_AI_SELLER_COPILOT=false
FEATURE_AI_BUSINESS_PROFILE=false
FEATURE_AI_MODERATION=false
FEATURE_SOCIAL_LOGIN=false
FEATURE_SUBSCRIPTIONS=false
FEATURE_LISTING_BOOSTS=false
FEATURE_MESSAGING=false
FEATURE_REVIEWS=false

# Moderation Settings
MODERATION_AUTO_APPROVE=false
MODERATION_SPAM_THRESHOLD=0.8
MODERATION_DUPLICATE_THRESHOLD=0.9
