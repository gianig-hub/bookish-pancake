# ============================================================
# EK Marketplace — Environment Variables Template
# ============================================================
# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real secrets.
# All values here are safe placeholders only.
# ============================================================


# ------------------------------------------------------------
# APP URLS
# URLs for each app in the monorepo.
# Update these per environment (local / staging / production).
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_NAME=EK Marketplace
NEXT_PUBLIC_SITE_DOMAIN=koldmarket.co.uk


# ------------------------------------------------------------
# API SERVER
# Configuration for the Express API service.
# ------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
API_CORS_ORIGIN=http://localhost:3000


# ------------------------------------------------------------
# DATABASE (PostgreSQL)
# Connection string and individual parameters.
# Use the connection string OR individual params — not both.
# ------------------------------------------------------------
DATABASE_URL=postgresql://ekuser:ekpassword@localhost:5432/ekmarketplace
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ekmarketplace
DB_USER=ekuser
DB_PASSWORD=ekpassword
DB_SSL=false


# ------------------------------------------------------------
# REDIS
# Used for job queues (BullMQ), caching, and rate limiting.
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=


# ------------------------------------------------------------
# AUTH / SESSION
# NextAuth or custom JWT session configuration.
# NEXTAUTH_SECRET must be a strong random string in production.
# Generate with: openssl rand -base64 32
# ------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-strong-secret-in-production
JWT_SECRET=replace-with-a-strong-jwt-secret
JWT_EXPIRES_IN=7d
SESSION_COOKIE_NAME=ek_session
SESSION_MAX_AGE=604800


# ------------------------------------------------------------
# EMAIL
# SMTP settings for transactional email (leads, alerts, auth).
# Uses SMTP. Can use SendGrid, Mailgun, Resend, etc.
# ------------------------------------------------------------
EMAIL_FROM=no-reply@koldmarket.co.uk
EMAIL_FROM_NAME=EK Marketplace
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_SECURE=false


# ------------------------------------------------------------
# STORAGE (S3-compatible)
# For listing images and uploaded files.
# Can use AWS S3, DigitalOcean Spaces, Cloudflare R2, etc.
# ------------------------------------------------------------
STORAGE_PROVIDER=s3
STORAGE_BUCKET=ek-marketplace-uploads
STORAGE_REGION=eu-west-2
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_ENDPOINT=https://s3.eu-west-2.amazonaws.com
STORAGE_PUBLIC_URL=https://cdn.koldmarket.co.uk
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_LISTING=10


# ------------------------------------------------------------
# PAYMENTS (Stripe)
# Used for subscription plans and listing boosts.
# Use Stripe test keys for development.
# ------------------------------------------------------------
STRIPE_PUBLIC_KEY=pk_test_replace_with_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret
STRIPE_PRICE_SELLER_PLUS=price_replace_with_seller_plus_price_id
STRIPE_PRICE_TRADER_PRO=price_replace_with_trader_pro_price_id
STRIPE_PRICE_DEALER=price_replace_with_dealer_price_id


# ------------------------------------------------------------
# AI / OPENAI
# Used in packages/ai and apps/worker for AI features.
# Isolated to worker/AI package — not used directly in web/api.
# ------------------------------------------------------------
OPENAI_API_KEY=sk-replace-with-your-openai-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000
AI_ENABLED=false
AI_MODERATION_ENABLED=false


# ------------------------------------------------------------
# LOGGING
# Log level and destination. Use 'debug' locally, 'info' in prod.
# ------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=pretty


# ------------------------------------------------------------
# FEATURE FLAGS
# Toggle features on/off without code changes.
# All false by default — enable per environment.
# ------------------------------------------------------------
FEATURE_AI_SEARCH=false
FEATURE_SELLER_COPILOT=false
FEATURE_BOOSTS=false
FEATURE_BUSINESS_PROFILES=true
FEATURE_WANTED_ADS=true
FEATURE_PAYMENTS=false


# ------------------------------------------------------------
# MODERATION SETTINGS
# Controls for listing moderation and content safety.
# ------------------------------------------------------------
MODERATION_AUTO_APPROVE=false
MODERATION_REQUIRE_REVIEW=true
MODERATION_MAX_REPORTS_BEFORE_HIDE=3
MODERATION_SPAM_THRESHOLD=0.85
