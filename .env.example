# ========================================
# EK MARKETPLACE - ENVIRONMENT CONFIGURATION TEMPLATE
# ========================================
#
# This is a template file for all environment variables used in EK Marketplace.
#
# USAGE:
#   - For local development: cp .env.example .env.local
#   - For VPS/production:    cp .env.example .env.production
#
# IMPORTANT:
#   - Never commit .env.local or .env.production to version control
#   - Fill in ALL values before running the application
#   - Do not use real secrets or API keys in this file
#   - Secrets marked with "CHANGE IN PRODUCTION" must be replaced before deploying
#
# ========================================


# ========================================
# SECTION 1: APPLICATION ENVIRONMENT
# Core settings that define how the app runs and where it lives
# ========================================

# The runtime environment (development | production | test)
NODE_ENV=development

# Public-facing URL of the main marketplace app
APP_URL=http://localhost:3000

# Public-facing URL of the admin panel
APP_URL_ADMIN=http://admin.localhost:3000

# Public URL of the API (used by frontend to make requests)
API_URL=http://localhost:4000

# Internal Docker network URL for server-to-server API calls (not exposed publicly)
# Example: http://api:4000 when using Docker Compose service names
API_INTERNAL_URL=http://api:4000

# The URL NextAuth.js uses for authentication callbacks
# Must match APP_URL in production
NEXTAUTH_URL=http://localhost:3000

# URL of the status page (uptime monitoring, incident reports)
STATUS_PAGE_URL=http://status.localhost:3000

# Enable verbose debug logging (true in development, false in production)
DEBUG_MODE=true


# ========================================
# SECTION 2: API CONFIGURATION
# Settings for the backend API server (rate limiting, CORS, timeouts)
# ========================================

# Port the API server listens on
API_PORT=4000

# Host the API server binds to (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
API_HOST=0.0.0.0

# Maximum number of API requests per window per client
API_RATE_LIMIT_REQUESTS=100

# Rate limit window duration in milliseconds (60000 = 1 minute)
API_RATE_LIMIT_WINDOW_MS=60000

# Comma-separated list of allowed CORS origins
# In production, replace with your actual domain(s)
CORS_ORIGINS=http://localhost:3000,http://admin.localhost:3000

# Maximum time (in ms) the API will wait before returning a timeout error
API_TIMEOUT_MS=30000


# ========================================
# SECTION 3: DATABASE CONFIGURATION
# PostgreSQL connection settings
# In production, use a strong password and consider DATABASE_SSL_MODE=require
# ========================================

# Full PostgreSQL connection string (used by Prisma / pg clients)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://ekuser:ekpassword@db:5432/ekmarket

# Database server hostname (use Docker service name in Docker Compose)
DATABASE_HOST=db

# Database server port
DATABASE_PORT=5432

# Name of the database schema
DATABASE_NAME=ekmarket

# Database username
DATABASE_USER=ekuser

# Database password — CHANGE IN PRODUCTION
DATABASE_PASSWORD=ekpassword

# SSL mode for database connection (disable | require | verify-full)
# Use 'require' or 'verify-full' in production for encrypted connections
DATABASE_SSL_MODE=disable


# ========================================
# SECTION 4: REDIS CONFIGURATION
# Redis is used for caching, session storage, and background job queues
# ========================================

# Full Redis connection URL
# Format: redis://:PASSWORD@HOST:PORT/DB_INDEX
REDIS_URL=redis://redis:6379/0

# Redis server hostname (use Docker service name in Docker Compose)
REDIS_HOST=redis

# Redis server port
REDIS_PORT=6379

# Redis password — leave empty if no authentication is configured
# In production, always set a strong password
REDIS_PASSWORD=

# Namespace prefix for all Redis keys (prevents collisions in shared Redis instances)
REDIS_NAMESPACE=ekmarket:


# ========================================
# SECTION 5: AUTHENTICATION & SESSION
# NextAuth.js, JWT, and session management settings
# All secrets MUST be replaced with strong random values in production
# ========================================

# Secret used to sign NextAuth.js session tokens — CHANGE IN PRODUCTION
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_key_here_change_in_production

# Session expiry in seconds (2592000 = 30 days)
SESSION_MAX_AGE=2592000

# Secret used to sign JWT tokens — CHANGE IN PRODUCTION
# Should be different from NEXTAUTH_SECRET
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Number of bcrypt hashing rounds for password storage (10 is a safe default)
# Increase for higher security at the cost of performance
PASSWORD_HASH_ROUNDS=10

# Minimum number of characters required for user passwords
PASSWORD_MIN_LENGTH=8

# Require at least one special character in passwords (true | false)
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# Where to store session data (database | redis)
SESSION_STORE=database


# ========================================
# SECTION 6: EMAIL CONFIGURATION
# Email sending provider and sender identity
# Use test API keys during development to avoid sending real emails
# ========================================

# Email sending provider (sendgrid | ses | smtp | mailgun)
EMAIL_PROVIDER=sendgrid

# API key for the chosen email provider — CHANGE IN PRODUCTION
EMAIL_API_KEY=sg_test_your_sendgrid_key_here

# The "from" email address shown in outgoing messages
EMAIL_FROM_ADDRESS=noreply@ekmarketplace.co.uk

# The display name shown alongside the from address
EMAIL_FROM_NAME=EK Marketplace

# Reply-to address for customer responses
EMAIL_REPLY_TO=support@ekmarketplace.co.uk


# ========================================
# SECTION 7: FILE STORAGE
# Local upload directory and S3-compatible object storage settings
# In production, use S3 or a compatible service (e.g. Cloudflare R2, MinIO)
# ========================================

# Local directory for uploaded files (relative to app root)
UPLOAD_DIR=public/uploads

# Maximum file upload size in bytes (5242880 = 5MB)
MAX_FILE_SIZE=5242880

# Comma-separated list of allowed file extensions for uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,webp,gif

# S3 bucket name for production file storage
S3_BUCKET=ekmarket-uploads

# AWS region where the S3 bucket is hosted (eu-west-2 = London)
S3_REGION=eu-west-2

# AWS IAM access key ID — CHANGE IN PRODUCTION
S3_ACCESS_KEY_ID=your_aws_access_key


# ========================================
# SECTION 8: PAYMENT PROCESSING
# Stripe payment integration settings
# Always use test keys in development (pk_test_ / sk_test_)
# Never commit live production keys to version control
# ========================================

# Stripe publishable key (safe to expose to frontend)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

# Stripe secret key — NEVER expose this publicly, CHANGE IN PRODUCTION
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe webhook signing secret — used to verify webhook events from Stripe
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret

# Default currency code for transactions (ISO 4217)
CURRENCY_CODE=GBP

# Minimum transaction amount in the smallest currency unit (100 = £1.00)
PAYMENT_MIN_AMOUNT=100


# ========================================
# SECTION 9: AI & LANGUAGE MODELS
# Configuration for AI features (search ranking, moderation, seller copilot)
# Set AI_ENABLE_LOGGING=true during development to debug AI responses
# ========================================

# AI provider to use (openai | anthropic | local)
AI_PROVIDER=openai

# OpenAI API key — CHANGE IN PRODUCTION
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model to use for AI features
# Example: gpt-4, gpt-4o, gpt-3.5-turbo
OPENAI_MODEL=gpt-4

# Maximum time (in ms) to wait for an AI response before timing out
AI_TIMEOUT_MS=30000

# Number of retry attempts if an AI request fails
AI_MAX_RETRIES=3

# Log AI requests and responses for debugging (true | false)
# Disable in production unless actively debugging
AI_ENABLE_LOGGING=true


# ========================================
# SECTION 10: LOGGING & MONITORING
# Application logging levels and error/analytics integrations
# ========================================

# Log verbosity level (error | warn | info | debug | verbose)
# Use 'info' in production, 'debug' during development
LOG_LEVEL=info

# Sentry DSN for error tracking — leave empty to disable Sentry
# Get yours at: https://sentry.io
SENTRY_DSN=https://your-sentry-dsn-here

# Sentry environment tag (development | staging | production)
SENTRY_ENVIRONMENT=development

# Enable detailed audit log for admin/moderation actions (true | false)
ENABLE_AUDIT_LOG=true

# Number of days to retain audit log entries before automatic deletion
AUDIT_LOG_RETENTION_DAYS=90

# Enable product analytics tracking (true | false)
ANALYTICS_ENABLED=true


# ========================================
# SECTION 11: FEATURE FLAGS
# Toggle individual product features on/off without code changes
# All AI features are disabled by default — enable once infrastructure is ready
# ========================================

# Enable AI-powered search ranking for marketplace listings
FEATURE_AI_SEARCH_RANKING=false

# Enable AI-powered listing moderation (spam, inappropriate content)
FEATURE_AI_MODERATION=false

# Enable AI-powered listing recommendations for buyers
FEATURE_AI_RECOMMENDATIONS=false

# Enable payment processing features (Stripe integration)
FEATURE_PAYMENTS_ENABLED=true

# Enable the AI-powered Seller Copilot (listing assistant)
FEATURE_SELLER_COPILOT=false

# Enable the AI-powered Business Copilot (lead reply drafting, FAQ generation)
FEATURE_BUSINESS_COPILOT=false

# Enable beta/experimental features not yet ready for all users
BETA_FEATURES_ENABLED=false

# Allow admin accounts to bypass API rate limiting
ADMIN_BYPASS_RATE_LIMIT=false


# ========================================
# SECTION 12: MODERATION SETTINGS
# Thresholds for automated content moderation and spam detection
# All values are decimal scores between 0.0 (low) and 1.0 (high confidence)
# ========================================

# AI confidence score above which a listing is flagged as spam (0.0–1.0)
# Example: 0.7 = flag if 70%+ confident it is spam
MODERATION_SPAM_THRESHOLD=0.7

# AI confidence score below which a listing is automatically approved (0.0–1.0)
# Example: 0.2 = auto-approve if less than 20% chance of being problematic
MODERATION_AUTO_APPROVE_THRESHOLD=0.2

# Maximum number of listings held in the moderation review queue at one time
MODERATION_REVIEW_QUEUE_SIZE=100

# Enable duplicate listing detection (true | false)
MODERATION_DUPLICATE_CHECK_ENABLED=true

# AI confidence score above which a listing price is flagged as anomalous (0.0–1.0)
# Example: 0.5 = flag if 50%+ confident the price is unusual
MODERATION_PRICE_ANOMALY_THRESHOLD=0.5
