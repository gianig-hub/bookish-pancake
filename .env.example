# ============================================================================
# EK MARKETPLACE - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local (development) or .env.production (VPS)
# Fill in all values for your environment
# Never commit actual secrets to Git
# ============================================================================


# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================
# Set to: development, staging, or production
# Controls logging detail, error handling, and feature availability
NODE_ENV=development

# The public URL of the main web application (buyer-facing)
APP_URL=http://localhost:3000

# The public URL of the admin panel
APP_URL_ADMIN=http://localhost:3001

# The public URL of the API (used by the frontend to make requests)
API_URL=http://localhost:4000

# Internal API URL (used by server-side code within Docker network)
# Example: http://api:4000 (Docker service name) in production
API_INTERNAL_URL=http://localhost:4000

# The URL used by NextAuth for authentication callbacks
# Must match APP_URL exactly
NEXTAUTH_URL=http://localhost:3000

# Optional URL for a status/uptime page
STATUS_PAGE_URL=http://localhost:3002

# Enable debug mode (verbose logging, stack traces, etc.)
# Set to false in staging and production
DEBUG_MODE=true


# ============================================================================
# API CONFIGURATION
# ============================================================================
# Settings for the backend API server

# Port the API server listens on
API_PORT=4000

# Host the API server binds to (use 0.0.0.0 to accept all connections)
API_HOST=0.0.0.0

# Maximum number of requests per window per IP for rate limiting
API_RATE_LIMIT_REQUESTS=100

# Rate limit window in milliseconds (60000 = 1 minute)
API_RATE_LIMIT_WINDOW_MS=60000

# Allowed CORS origins (comma-separated list of URLs)
# Example: http://localhost:3000,http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Request timeout in milliseconds (30000 = 30 seconds)
API_TIMEOUT_MS=30000


# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL database connection settings
# DATABASE_URL is the primary connection string (used by Prisma or pg)
# The individual fields below are used for local development with Docker Compose

# Full PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=disable
DATABASE_URL=postgresql://ek_user:change_me_in_production@localhost:5432/ek_marketplace

# Database server hostname (use 'db' if using Docker Compose service name)
DATABASE_HOST=localhost

# Database server port (default PostgreSQL port is 5432)
DATABASE_PORT=5432

# Name of the database to connect to
DATABASE_NAME=ek_marketplace

# PostgreSQL username
DATABASE_USER=ek_user

# PostgreSQL password — change this before deploying to production
DATABASE_PASSWORD=change_me_in_production

# SSL mode for database connections
# Use 'disable' for local dev, 'require' for production VPS
DATABASE_SSL_MODE=disable


# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Redis is used for caching, rate limiting, and job queues

# Full Redis connection string
# Format: redis://:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379

# Redis server hostname (use 'redis' if using Docker Compose service name)
REDIS_HOST=localhost

# Redis server port (default is 6379)
REDIS_PORT=6379

# Redis password — leave blank for local development without auth
REDIS_PASSWORD=

# Namespace/prefix for Redis keys (prevents collisions across environments)
REDIS_NAMESPACE=ek_marketplace


# ============================================================================
# AUTHENTICATION & SESSION
# ============================================================================
# Settings for NextAuth.js, JWT, and session management
# NEXTAUTH_SECRET must be a random 32-byte string — generate with:
#   openssl rand -base64 32

# Secret used to sign and encrypt NextAuth session tokens
# Must be a long random string — never reuse across environments
NEXTAUTH_SECRET=your_nextauth_secret_key_here_change_me

# How long sessions stay valid (in seconds)
# 2592000 = 30 days
SESSION_MAX_AGE=2592000

# Secret key used to sign JWT tokens
# Must be different from NEXTAUTH_SECRET — generate with:
#   openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here_change_me

# Number of bcrypt rounds for password hashing
# Higher is more secure but slower — 12 is a good balance
PASSWORD_HASH_ROUNDS=12

# Minimum password length required at registration
PASSWORD_MIN_LENGTH=8

# Require at least one special character in passwords
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# Where to store session data (database or redis)
SESSION_STORE=database


# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
# Settings for sending transactional emails (registration, alerts, leads, etc.)
# Supported providers: sendgrid, ses, smtp

# Email service provider to use
EMAIL_PROVIDER=sendgrid

# API key for the email provider — get this from your provider's dashboard
EMAIL_API_KEY=your_email_api_key_here

# The "from" email address used when sending emails
EMAIL_FROM_ADDRESS=noreply@example.com

# The display name shown in the "from" field of sent emails
EMAIL_FROM_NAME=EK Marketplace

# Reply-to address for emails that should allow replies
EMAIL_REPLY_TO=support@example.com


# ============================================================================
# FILE STORAGE
# ============================================================================
# Settings for user-uploaded files (listing images, business logos, etc.)
# For local development, files are stored on disk
# For production, consider using S3-compatible object storage

# Directory to store uploaded files (relative to API root)
UPLOAD_DIR=./uploads

# Maximum allowed file size per upload in bytes
# 10485760 = 10MB
MAX_FILE_SIZE=10485760

# Comma-separated list of allowed MIME types for uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Optional: S3 bucket name for production file storage
# Leave blank to use local disk storage
S3_BUCKET=

# Optional: AWS region for the S3 bucket
S3_REGION=

# Optional: AWS access key ID for S3 authentication
S3_ACCESS_KEY_ID=


# ============================================================================
# PAYMENT PROCESSING
# ============================================================================
# Stripe is used for subscriptions, boosts, and any paid features
# Use test keys (pk_test_... / sk_test_...) during development
# Never use production keys in development environments

# Stripe publishable key — safe to expose in frontend code
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# Stripe secret key — keep this private, never expose in frontend
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe webhook signing secret — used to verify webhook events from Stripe
# Get this from your Stripe webhook settings
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Default currency code (ISO 4217 format)
CURRENCY_CODE=GBP

# Minimum payment amount in the smallest currency unit (pence for GBP)
# 100 = £1.00
PAYMENT_MIN_AMOUNT=100


# ============================================================================
# AI & LANGUAGE MODELS
# ============================================================================
# Settings for AI-powered features (search, listing assistance, moderation)
# AI features are controlled by feature flags — see FEATURE FLAGS section
# Supported providers: openai, anthropic

# AI service provider to use
AI_PROVIDER=openai

# OpenAI API key — get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk_your_openai_api_key_here

# OpenAI model to use for AI features
# Options: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o

# Timeout for AI API requests in milliseconds (30000 = 30 seconds)
AI_TIMEOUT_MS=30000

# Maximum number of retries for failed AI API requests
AI_MAX_RETRIES=3

# Log all AI requests and responses for debugging and auditing
# Recommended: true in development, false in production (PII concerns)
AI_ENABLE_LOGGING=true


# ============================================================================
# LOGGING & MONITORING
# ============================================================================
# Controls how much detail is logged and where errors are sent

# Minimum log level to output
# Options: debug, info, warn, error (from most to least verbose)
LOG_LEVEL=debug

# Optional: Sentry DSN for error tracking
# Get this from your Sentry project settings
# Leave blank to disable Sentry error reporting
SENTRY_DSN=

# Environment label sent to Sentry with each error report
SENTRY_ENVIRONMENT=development

# Enable audit logging (records user actions like posting, editing, deleting)
# Recommended: true in production for compliance and debugging
ENABLE_AUDIT_LOG=true

# Number of days to retain audit log entries before purging
AUDIT_LOG_RETENTION_DAYS=90

# Enable usage analytics (page views, search queries, etc.)
ANALYTICS_ENABLED=false


# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable or disable features without changing code
# Set to true/false — all flags default to false in production until ready

# Enable AI-powered search result ranking
FEATURE_AI_SEARCH_RANKING=false

# Enable AI moderation for new listings (spam/risk scoring)
FEATURE_AI_MODERATION=false

# Enable AI-powered listing recommendations for buyers
FEATURE_AI_RECOMMENDATIONS=false

# Enable payment processing (subscriptions, boosts)
# Disable to run the platform in free-only mode during early testing
FEATURE_PAYMENTS_ENABLED=false

# Enable the Seller Copilot (AI title/description/category assistant)
FEATURE_SELLER_COPILOT=false

# Enable the Business Copilot (AI profile and lead reply assistant)
FEATURE_BUSINESS_COPILOT=false

# Enable beta features for early access users
BETA_FEATURES_ENABLED=false

# Allow admin accounts to bypass API rate limiting
# Set to false in production unless testing requires it
ADMIN_BYPASS_RATE_LIMIT=false


# ============================================================================
# MODERATION SETTINGS
# ============================================================================
# Thresholds and settings for the listing moderation system
# Scores are typically 0.0–1.0 unless otherwise noted

# Spam confidence score above which a listing is flagged as spam
# Lower value = stricter (more false positives)
MODERATION_SPAM_THRESHOLD=0.8

# Confidence score above which a listing is automatically approved
# without human review (keep high to reduce bad auto-approvals)
MODERATION_AUTO_APPROVE_THRESHOLD=0.95

# Maximum number of listings in the moderation review queue
# Listings beyond this limit will be queued and processed in order
MODERATION_REVIEW_QUEUE_SIZE=500

# Enable duplicate listing detection (checks for near-identical listings)
MODERATION_DUPLICATE_CHECK_ENABLED=true

# Price anomaly detection threshold (ratio above/below category average)
# Example: 3.0 = flag listings priced more than 3x the category median
MODERATION_PRICE_ANOMALY_THRESHOLD=3.0
