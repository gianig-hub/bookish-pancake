# =============================================================================
# EK Marketplace — Environment Variables Example
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# =============================================================================
# APP URLS
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NODE_ENV=development

# =============================================================================
# API (apps/api)
# =============================================================================
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000

# =============================================================================
# DATABASE (PostgreSQL)
# TODO: Connect once Prisma schema is set up (Phase 2)
# =============================================================================
DATABASE_URL=postgresql://ekuser:ekpassword@localhost:5432/ekdb
POSTGRES_USER=ekuser
POSTGRES_PASSWORD=ekpassword
POSTGRES_DB=ekdb

# =============================================================================
# REDIS (sessions, caching, queues)
# TODO: Wire up for session persistence (Phase 2)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# AUTH / SESSION
# Use strong random secrets in production (openssl rand -base64 32)
# TODO: Use these once cookie signing / JWT is added (Phase 2)
# =============================================================================
SESSION_SECRET=replace-with-a-strong-random-secret
JWT_SECRET=replace-with-a-strong-random-secret
SESSION_TTL_DAYS=7

# =============================================================================
# EMAIL (transactional)
# TODO: Set up before enabling email verification (Phase 2)
# =============================================================================
EMAIL_FROM=noreply@ekmarketplace.co.uk
# Resend (recommended):
# RESEND_API_KEY=re_xxxxxxxxxxxx
# Or SMTP:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=your-smtp-password

# =============================================================================
# STORAGE (images, attachments)
# TODO: Set up for listing images (Phase 2)
# =============================================================================
STORAGE_PROVIDER=local
# S3 / Cloudflare R2:
# STORAGE_BUCKET=ek-marketplace-uploads
# STORAGE_REGION=auto
# STORAGE_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# STORAGE_ACCESS_KEY=xxxx
# STORAGE_SECRET_KEY=xxxx

# =============================================================================
# PAYMENTS (Stripe)
# TODO: Set up for subscriptions and boosts (Phase 3)
# =============================================================================
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
# STRIPE_SECRET_KEY=sk_test_xxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxx

# =============================================================================
# AI / OPENAI
# TODO: Set up when AI features are built (Phase 3)
# =============================================================================
# OPENAI_API_KEY=sk-xxxx
# OPENAI_MODEL=gpt-4o
# AI_RATE_LIMIT_RPM=60

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
# LOG_FORMAT=json  # use 'json' in production

# =============================================================================
# FEATURE FLAGS
# Set to 'true' to enable features during development
# =============================================================================
FEATURE_AI_SEARCH=false
FEATURE_AI_POSTING=false
FEATURE_PAYMENTS=false
FEATURE_EMAIL_VERIFICATION=false
FEATURE_SOCIAL_LOGIN=false

# =============================================================================
# MODERATION
# TODO: Configure when moderation tools are built (Phase 3)
# =============================================================================
MODERATION_AUTO_APPROVE=true
# MODERATION_OPENAI_MODEL=gpt-4o-mini
# MODERATION_SPAM_THRESHOLD=0.85
