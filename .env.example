# ==============================================================================
# EK Marketplace — Environment Configuration Template
# ==============================================================================
#
# USAGE:
#   Local development:  cp .env.example .env.local
#   VPS production:     cp .env.example .env.production  (then fill real values)
#
# SECURITY:
#   - NEVER commit .env.local or .env.production to Git
#   - On the VPS: chmod 600 .env.production
#   - Rotate all secrets before going live
#   - This file contains SAFE PLACEHOLDER VALUES ONLY — no real secrets
#
# DOCS:
#   Deployment guide: docs/deployment/VPS-SETUP.md
#   AI placement map: docs/ai/AI-PLACEMENT-MAP.md
#
# ==============================================================================


# ==============================================================================
# 1. APPLICATION ENVIRONMENT
# The core runtime settings that define which environment the app is running in.
# NODE_ENV drives framework optimisations, error verbosity, and feature gates.
# All URL variables must match the actual domain/subdomain used for the env.
# ==============================================================================

# Runtime environment: development | staging | production
NODE_ENV=development

# Public-facing web application URL (used in emails, canonical links, sitemaps)
APP_URL=http://localhost:3000

# Backend API base URL (used by the frontend to make API calls)
API_URL=http://localhost:4000

# NextAuth callback URL — must match APP_URL exactly (including protocol and port)
NEXTAUTH_URL=http://localhost:3000

# Admin dashboard URL (restrict access to trusted IPs on production)
ADMIN_URL=http://localhost:3001

# Uptime / status page URL (public or internal monitoring page)
STATUS_URL=http://status.localhost:3000

# Internal service-to-service base URL (not exposed publicly)
INTERNAL_API_URL=http://localhost:4000

# Enable verbose debug output — set to false in production
DEBUG_MODE=true


# ==============================================================================
# 2. API CONFIGURATION
# Settings that control how the backend API server behaves.
# Rate limiting protects against abuse; CORS controls which origins can call
# the API; timeout prevents runaway requests from blocking the server.
# ==============================================================================

# Port the API server listens on
API_PORT=4000

# Host the API server binds to (use 0.0.0.0 in Docker; 127.0.0.1 for local)
API_HOST=0.0.0.0

# Rate limiting — maximum requests allowed per window per IP
RATE_LIMIT_MAX=100

# Rate limiting — window duration in milliseconds (e.g. 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Comma-separated list of origins allowed to call the API (CORS)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Maximum time (ms) before an API request times out
REQUEST_TIMEOUT_MS=30000


# ==============================================================================
# 3. DATABASE (PostgreSQL)
# Primary relational database for all marketplace data.
# The full DATABASE_URL takes priority; individual parts are used by some ORMs
# and migration tools (e.g. Drizzle, Prisma) for granular control.
# In production, always enable SSL.
# ==============================================================================

# Full PostgreSQL connection string (takes precedence over individual vars below)
DATABASE_URL=postgresql://ek_user:change_me_in_production@localhost:5432/ek_marketplace

# Individual connection components (useful for migration tools and scripts)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ek_marketplace
DB_USER=ek_user
DB_PASSWORD=change_me_in_production

# Maximum concurrent database connections in the pool
DB_POOL_MAX=10

# Enable SSL for the database connection — always true in production
DB_SSL=false


# ==============================================================================
# 4. REDIS
# Used for caching, session storage, job queues (BullMQ), and pub/sub.
# REDIS_URL takes precedence; individual vars are available for tools that
# need them separately. Set a namespace to avoid key collisions between apps
# sharing the same Redis instance.
# ==============================================================================

# Full Redis connection string
REDIS_URL=redis://localhost:6379

# Individual connection components
REDIS_HOST=localhost
REDIS_PORT=6379

# Redis password — leave empty for local dev without auth
REDIS_PASSWORD=

# Key prefix / namespace to avoid collisions (e.g. ek:prod: or ek:staging:)
REDIS_NAMESPACE=ek:dev:


# ==============================================================================
# 5. AUTHENTICATION & SESSIONS
# NextAuth.js handles authentication. NEXTAUTH_SECRET must be a long, random
# string — generate one with: openssl rand -base64 32
# Session and JWT settings control token lifetime and security posture.
# ==============================================================================

# Secret used to sign and encrypt NextAuth tokens — MUST be changed in production
NEXTAUTH_SECRET=your_nextauth_secret_change_me_in_production

# JWT signing secret (used for custom JWT tokens outside NextAuth if needed)
JWT_SECRET=your_jwt_secret_change_me_in_production

# JWT access token expiry (e.g. 15m, 1h)
JWT_EXPIRES_IN=1h

# Session maximum age in seconds (e.g. 86400 = 24 hours, 604800 = 7 days)
SESSION_MAX_AGE=86400

# Cookie security — set to true in production (requires HTTPS)
SESSION_COOKIE_SECURE=false

# Minimum password length enforced at registration and password change
PASSWORD_MIN_LENGTH=8

# Require at least one uppercase, one number, one special character
PASSWORD_REQUIRE_STRONG=true


# ==============================================================================
# 6. EMAIL SERVICE
# Transactional emails: account verification, password reset, notifications,
# listing alerts, and lead notifications.
# Supported providers: sendgrid | aws-ses | smtp | resend
# Set EMAIL_API_KEY to the provider's API key or use SMTP credentials below.
# ==============================================================================

# Email sending provider
EMAIL_PROVIDER=sendgrid

# API key for the chosen provider (SendGrid, Resend, etc.)
EMAIL_API_KEY=your_email_api_key_here

# Sender display name shown in recipients' inboxes
EMAIL_FROM_NAME=EK Marketplace

# Sender email address (must be verified with your provider)
EMAIL_FROM_ADDRESS=noreply@example.com

# Reply-to address for customer enquiries
EMAIL_REPLY_TO=support@example.com

# SMTP fallback settings (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp_user@example.com
SMTP_PASSWORD=your_smtp_password_here


# ==============================================================================
# 7. FILE STORAGE
# Handles user-uploaded images and documents (listing photos, business logos).
# In development, files are stored locally under UPLOAD_DIR.
# In production, use S3-compatible object storage (AWS S3, Cloudflare R2, etc.)
# and set STORAGE_PROVIDER=s3.
# ==============================================================================

# Storage backend: local | s3
STORAGE_PROVIDER=local

# Local upload directory (relative to project root, used when STORAGE_PROVIDER=local)
UPLOAD_DIR=./uploads

# Maximum allowed upload size in bytes (e.g. 10485760 = 10 MB)
MAX_FILE_SIZE=10485760

# Comma-separated list of permitted MIME types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif,application/pdf

# S3 / R2 settings — only required when STORAGE_PROVIDER=s3
S3_BUCKET=your-bucket-name
S3_REGION=eu-west-2
S3_ACCESS_KEY_ID=your_s3_access_key_id_here
S3_SECRET_ACCESS_KEY=your_s3_secret_access_key_here

# Custom endpoint for S3-compatible providers (e.g. Cloudflare R2, MinIO)
# Leave empty to use the default AWS S3 endpoint
S3_ENDPOINT=


# ==============================================================================
# 8. PAYMENT PROCESSING (Stripe)
# Handles listing boosts, subscription plans, and marketplace fees.
# Use Stripe test keys (sk_test_ / pk_test_) in development and staging.
# NEVER commit live keys — rotate immediately if accidentally exposed.
# ==============================================================================

# Stripe publishable key (safe to expose to the browser)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# Stripe secret key (server-side only — never expose to the browser)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe webhook signing secret (from the Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Default currency for all transactions (ISO 4217 code)
CURRENCY_CODE=GBP

# Minimum transaction amount in the smallest currency unit (e.g. 50 = £0.50)
STRIPE_MIN_AMOUNT=50


# ==============================================================================
# 9. AI & LANGUAGE MODELS
# Powers Seller Copilot (title/description writing), AI search ranking,
# spam detection, and admin moderation assistance.
# See docs/ai/AI-PLACEMENT-MAP.md for full AI placement strategy.
# ==============================================================================

# AI provider: openai | anthropic | ollama (local)
AI_PROVIDER=openai

# OpenAI API key — keep server-side only; never expose to the browser
OPENAI_API_KEY=your_openai_api_key_here

# Default OpenAI model to use for generation tasks
OPENAI_MODEL=gpt-4o-mini

# Maximum tokens per AI response (controls cost and response length)
OPENAI_MAX_TOKENS=1000

# Number of retry attempts on transient API failures
AI_RETRY_ATTEMPTS=3

# Timeout in milliseconds for a single AI API call
AI_TIMEOUT_MS=15000

# Log AI prompts and responses for debugging (disable in production for privacy)
AI_LOGGING_ENABLED=true


# ==============================================================================
# 10. LOGGING & MONITORING
# Controls application log verbosity and integration with external monitoring
# and error-tracking services.
# ==============================================================================

# Log verbosity: error | warn | info | http | debug
LOG_LEVEL=info

# Sentry DSN for error tracking — leave empty to disable
SENTRY_DSN=

# Sentry environment tag (helps filter events in the Sentry dashboard)
SENTRY_ENVIRONMENT=development

# Enable structured audit logging for sensitive actions (listings, payments, bans)
AUDIT_LOG_ENABLED=true

# Audit log retention in days (older records are pruned by a scheduled job)
AUDIT_LOG_RETENTION_DAYS=90

# Enable product analytics event tracking
ANALYTICS_ENABLED=false


# ==============================================================================
# 11. FEATURE FLAGS
# Toggle features on/off without a code deploy. Useful for phased rollouts,
# beta testing, and disabling features that are not ready for production.
# See ROADMAP.md for which phase each feature is targeted.
# ==============================================================================

# --- AI Features ---
# Enable AI-powered search ranking on marketplace browse pages (Phase 3)
FEATURE_AI_SEARCH=false

# Enable Seller Copilot: title and description writing assistant (Phase 3)
FEATURE_AI_SELLER_COPILOT=false

# Enable Business Copilot: profile writing and lead reply drafting (Phase 3)
FEATURE_AI_BUSINESS_COPILOT=false

# Enable AI moderation assistant for admin review queue (Phase 3)
FEATURE_AI_MODERATION=false

# Enable AI-powered listing recommendations ("You may also like") (Phase 3+)
FEATURE_AI_RECOMMENDATIONS=false

# --- Payment Features ---
# Enable Stripe payment processing for boosts and subscriptions (Phase 2)
FEATURE_PAYMENTS=false

# --- Beta & Experimental Features ---
# Enable experimental features only for users with the beta flag on their account
FEATURE_BETA_ACCESS=false

# Bypass email verification in development / automated testing environments
FEATURE_SKIP_EMAIL_VERIFICATION=false


# ==============================================================================
# 12. MODERATION SETTINGS
# Thresholds and switches that control the automated moderation pipeline.
# Listings above SPAM_SCORE_THRESHOLD are flagged for manual review.
# Listings below AUTO_APPROVE_THRESHOLD bypass the review queue entirely.
# Tune these values based on observed false-positive/negative rates.
# ==============================================================================

# Confidence score (0–1) above which a listing is flagged as potential spam
SPAM_SCORE_THRESHOLD=0.75

# Confidence score (0–1) below which a new listing is automatically approved
# without human review (only active when FEATURE_AI_MODERATION=true)
AUTO_APPROVE_THRESHOLD=0.20

# Enable duplicate listing detection (compares title + description similarity)
DUPLICATE_DETECTION_ENABLED=true

# Similarity ratio (0–1) above which two listings are considered duplicates
DUPLICATE_SIMILARITY_THRESHOLD=0.85

# Enable price anomaly detection (flags listings priced far outside the norm)
PRICE_ANOMALY_DETECTION_ENABLED=true

# Standard deviation multiplier used to define a price anomaly
# (e.g. 3 = flag prices more than 3 SDs from the category mean)
PRICE_ANOMALY_STDDEV_MULTIPLIER=3
