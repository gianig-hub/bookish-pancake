# ==============================================================================
# EK Marketplace — Environment Configuration
# ==============================================================================
# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real secrets.
# Each section below controls a distinct part of the application.
# ==============================================================================


# ------------------------------------------------------------------------------
# APP URLS
# URLs for each part of the monorepo. Used for CORS, redirects, email links.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_NAME=EK Marketplace
NEXT_PUBLIC_SITE_DOMAIN=ekmarketplace.co.uk


# ------------------------------------------------------------------------------
# API SERVER
# Core settings for the Express API service.
# ------------------------------------------------------------------------------
API_PORT=4000
API_ENV=development
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000


# ------------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# Connection string used by Prisma ORM.
# For local dev, matches the docker-compose postgres service.
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://ekuser:ekpassword@localhost:5432/ekmarketplace
# Separate read-replica URL for Phase 4+ (leave blank for now)
DATABASE_READ_URL=


# ------------------------------------------------------------------------------
# REDIS
# Used for job queues (BullMQ), caching, and rate limiting.
# For local dev, matches the docker-compose redis service.
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=


# ------------------------------------------------------------------------------
# AUTH / SESSION
# Used by NextAuth (web) and JWT middleware (api).
# NEXTAUTH_SECRET and JWT_SECRET must be strong random strings in production.
# Generate with: openssl rand -base64 32
# ------------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-strong-random-secret
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRES_IN=7d
SESSION_COOKIE_NAME=ek_session


# ------------------------------------------------------------------------------
# EMAIL
# SMTP settings for transactional email (listing published, enquiry received).
# Use Mailpit (docker-compose) for local dev to catch emails without sending.
# ------------------------------------------------------------------------------
EMAIL_FROM=noreply@ekmarketplace.co.uk
EMAIL_FROM_NAME=EK Marketplace
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false


# ------------------------------------------------------------------------------
# STORAGE (File Uploads)
# Used for listing images and business logos.
# LOCAL: files saved to local disk (docker volume) for development.
# PRODUCTION: switch to S3-compatible storage (Cloudflare R2 recommended).
# ------------------------------------------------------------------------------
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
# S3 / Cloudflare R2 (leave blank for local dev)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
# Public URL prefix for serving uploaded files
STORAGE_PUBLIC_URL=http://localhost:4000/uploads
# Max upload size in MB
MAX_UPLOAD_SIZE_MB=10


# ------------------------------------------------------------------------------
# PAYMENTS (Stripe)
# Used for subscription plans and listing boosts.
# TODO: Wire up Stripe Checkout in Phase 2.
# Use Stripe test keys for local dev — never use live keys in .env.local.
# ------------------------------------------------------------------------------
STRIPE_PUBLIC_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me


# ------------------------------------------------------------------------------
# AI / OPENAI
# Used by packages/ai and apps/worker for AI-assisted features.
# AI features are disabled by default — controlled by FEATURE_AI_ENABLED below.
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-replace-with-your-openai-key
OPENAI_MODEL=gpt-4o-mini
# Max tokens per AI response (keep low for cost control)
AI_MAX_TOKENS=500
# Temperature: 0 = deterministic, 1 = creative (0.3–0.5 recommended for listings)
AI_TEMPERATURE=0.4


# ------------------------------------------------------------------------------
# LOGGING
# Controls log level and output format.
# Use "debug" locally, "info" or "warn" in production.
# ------------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=pretty


# ------------------------------------------------------------------------------
# FEATURE FLAGS
# Toggle features on/off without code changes.
# Set to "true" or "false" as strings.
# ------------------------------------------------------------------------------
# AI-assisted features (search, posting suggestions, moderation)
FEATURE_AI_ENABLED=false
# Stripe payments and plan enforcement
FEATURE_PAYMENTS_ENABLED=false
# Listing boosts (requires payments)
FEATURE_BOOSTS_ENABLED=false
# Business profiles (Phase 2)
FEATURE_BUSINESSES_ENABLED=true
# Wanted ads posting
FEATURE_WANTED_ADS_ENABLED=true
# Maintenance mode — shows a static maintenance page to all visitors
FEATURE_MAINTENANCE_MODE=false


# ------------------------------------------------------------------------------
# MODERATION
# Controls automatic moderation behaviour.
# TODO: Connect to AI moderation pipeline in Phase 3.
# ------------------------------------------------------------------------------
# Auto-approve listings without manual review (disable in production)
MODERATION_AUTO_APPROVE=true
# Minimum AI confidence score to auto-approve (0–1)
MODERATION_AI_THRESHOLD=0.85
# Maximum image count per listing
LISTING_MAX_IMAGES=10
