# =============================================================================
# .env.example — EK Marketplace Monorepo
# =============================================================================
#
# Copy this file to .env.local (local development) or .env.production (server)
# and fill in the appropriate values for your environment.
#
# Usage:
#   cp .env.example .env.local          # for local development
#   cp .env.example .env.production     # for production (on VPS, never in Git)
#
# IMPORTANT:
#   - Never commit .env.local or .env.production to Git.
#   - This file contains ONLY safe placeholder values — no real secrets.
#   - Variables marked [REQUIRED] must be set before the app will start.
#   - Variables marked [OPTIONAL] have sensible defaults shown here.
#
# =============================================================================


# =============================================================================
# 1. APPLICATION ENVIRONMENT
# General settings that identify the runtime environment and public URLs.
# =============================================================================

# Runtime environment: development | staging | production
NODE_ENV=development

# Public-facing URL of the main Next.js storefront
APP_URL=http://localhost:3000

# Internal base URL for the API service (used server-side)
API_URL=http://localhost:4000

# Public URL used by NextAuth for callbacks and redirects [REQUIRED in production]
NEXTAUTH_URL=http://localhost:3000

# Application display name (used in emails, browser title, etc.)
APP_NAME=EK Marketplace

# Application version (can be injected at build time via CI)
APP_VERSION=1.0.0

# Enable verbose debug output (true | false) — disable in production
DEBUG_MODE=true


# =============================================================================
# 2. API CONFIGURATION
# Settings that control how the REST / GraphQL API layer behaves.
# =============================================================================

# Port the API server listens on
API_PORT=4000

# Host/interface the API server binds to (0.0.0.0 to accept all interfaces)
API_HOST=0.0.0.0

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Maximum number of requests per IP per window (rate limiting)
RATE_LIMIT_MAX=100

# Rate-limit rolling window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Timeout for upstream / external HTTP requests in milliseconds
REQUEST_TIMEOUT_MS=30000


# =============================================================================
# 3. DATABASE
# PostgreSQL connection settings.  Use DATABASE_URL for most clients,
# or individual variables when DATABASE_URL is not supported.
# =============================================================================

# Full PostgreSQL connection string [REQUIRED]
DATABASE_URL=postgresql://ek_user:changeme@localhost:5432/ek_marketplace

# Database host
DB_HOST=localhost

# Database port
DB_PORT=5432

# Database name
DB_NAME=ek_marketplace

# Database username
DB_USER=ek_user

# Database password [REQUIRED — change before deployment]
DB_PASSWORD=changeme

# Enable SSL for database connection (true | false) — recommended in production
DB_SSL=false


# =============================================================================
# 4. REDIS
# Redis connection settings used for caching, session storage, and job queues.
# =============================================================================

# Full Redis connection string [REQUIRED]
REDIS_URL=redis://localhost:6379

# Redis host
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis database index (0–15)
REDIS_DB=0

# Key namespace prefix to avoid collisions in shared Redis instances
REDIS_NAMESPACE=ek


# =============================================================================
# 5. AUTHENTICATION & SESSION
# Secrets and settings for NextAuth, JWT tokens, and session management.
# All secrets must be long random strings in production.
# =============================================================================

# Secret used by NextAuth to sign/encrypt cookies and tokens [REQUIRED]
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Secret key used to sign JWT tokens [REQUIRED]
JWT_SECRET=replace-with-another-long-random-secret

# JWT expiry duration (e.g. 7d, 24h, 3600)
JWT_EXPIRES_IN=7d

# Duration before a session is considered expired (in seconds)
SESSION_MAX_AGE=604800

# Bcrypt salt rounds for password hashing (higher = more secure but slower)
BCRYPT_SALT_ROUNDS=12

# Minimum allowed password length
PASSWORD_MIN_LENGTH=8

# Require mixed-case + numbers + symbols (true | false)
PASSWORD_REQUIRE_COMPLEXITY=true


# =============================================================================
# 6. EMAIL
# Transactional email provider settings (e.g. Resend, SendGrid, Postmark).
# =============================================================================

# Email provider driver: resend | sendgrid | postmark | smtp
EMAIL_PROVIDER=resend

# API key for the chosen email provider [REQUIRED in production]
EMAIL_API_KEY=re_placeholder_api_key

# Sender name and address shown to recipients
EMAIL_FROM=EK Marketplace <noreply@example.com>

# Reply-to address (can differ from the sender)
EMAIL_REPLY_TO=support@example.com

# Optional: Email address that receives admin/system alerts
EMAIL_ADMIN=admin@example.com


# =============================================================================
# 7. FILE STORAGE
# Local disk and/or S3-compatible object storage for uploaded files.
# =============================================================================

# Local directory for uploads (relative or absolute path)
UPLOAD_DIR=./uploads

# Maximum file upload size in bytes (default: 10 MB)
MAX_FILE_SIZE_BYTES=10485760

# Comma-separated list of allowed MIME types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# S3-compatible bucket name (leave blank to use local disk)
S3_BUCKET=your-bucket-name

# S3-compatible endpoint URL (blank = AWS default; set for MinIO / Backblaze B2)
S3_ENDPOINT=https://s3.amazonaws.com

# AWS / S3 credentials [REQUIRED when using S3]
S3_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET_ACCESS_KEY


# =============================================================================
# 8. PAYMENT PROCESSING
# Stripe integration keys and settings.
# Use test-mode keys (sk_test_ / pk_test_) in development.
# =============================================================================

# Stripe publishable key (safe to expose client-side)
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# Stripe secret key [REQUIRED — never expose client-side]
STRIPE_SECRET_KEY=sk_test_placeholder

# Stripe webhook signing secret (from your Stripe dashboard) [REQUIRED]
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Default currency code (ISO 4217)
PAYMENT_CURRENCY=GBP

# Minimum transaction amount in the smallest currency unit (e.g. pence for GBP)
PAYMENT_MIN_AMOUNT_PENCE=100


# =============================================================================
# 9. AI & LANGUAGE MODELS
# Configuration for AI/LLM features (moderation, recommendations, etc.).
# =============================================================================

# AI provider: openai | anthropic | local
AI_PROVIDER=openai

# OpenAI API key [REQUIRED when AI_PROVIDER=openai]
OPENAI_API_KEY=sk-placeholder-openai-key

# Default model to use for AI features
AI_MODEL=gpt-4o-mini

# Maximum tokens per AI request
AI_MAX_TOKENS=1024

# Number of retries on AI request failure
AI_MAX_RETRIES=3

# Log AI prompts and responses for debugging (true | false) — disable in production
AI_LOG_REQUESTS=false


# =============================================================================
# 10. LOGGING & MONITORING
# Log verbosity, error tracking, and analytics settings.
# =============================================================================

# Minimum log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=debug

# Log format: pretty (human-readable) | json (structured, for log aggregators)
LOG_FORMAT=pretty

# Sentry DSN for error tracking (leave blank to disable)
SENTRY_DSN=

# Sentry environment tag (mirrors NODE_ENV by default)
SENTRY_ENVIRONMENT=development

# Enable audit logging for sensitive operations (true | false)
AUDIT_LOG_ENABLED=true

# Optional: Analytics/telemetry write key (e.g. PostHog, Segment)
ANALYTICS_WRITE_KEY=


# =============================================================================
# 11. FEATURE FLAGS
# Toggle features on/off without a code deployment.
# All flags default to false; enable only what is ready.
# =============================================================================

# Enable AI-powered listing description generation
FEATURE_AI_LISTING_DESCRIPTIONS=false

# Enable AI-powered search / recommendation engine
FEATURE_AI_SEARCH=false

# Enable Stripe payment processing
FEATURE_PAYMENTS=false

# Enable real-time messaging between buyers and sellers
FEATURE_MESSAGING=false

# Enable new beta features for opted-in users
FEATURE_BETA=false

# Allow admin users to bypass moderation queue
FEATURE_ADMIN_BYPASS_MODERATION=false

# Enable buyer/seller review and rating system
FEATURE_REVIEWS=false

# Show banner for scheduled maintenance window
FEATURE_MAINTENANCE_MODE=false


# =============================================================================
# 12. MODERATION SETTINGS
# Controls for automated content and listing moderation.
# =============================================================================

# Spam confidence threshold (0.0–1.0); listings above this are flagged
MODERATION_SPAM_THRESHOLD=0.75

# Automatically approve listings that pass all automated checks (true | false)
MODERATION_AUTO_APPROVE=false

# Flag listings with duplicate titles/descriptions (true | false)
MODERATION_CHECK_DUPLICATES=true

# Maximum percentage deviation from category average price before flagging
MODERATION_PRICE_ANOMALY_PERCENT=200

# Maximum number of active listings allowed per user (0 = unlimited)
MODERATION_MAX_LISTINGS_PER_USER=50
