# EK Marketplace — Environment Variables

# Copy this file to .env.local for local development
# Copy to .env.production for production (never commit .env.production or .env.local)

# =============================================================================
# APP
# =============================================================================
NODE_ENV=development
APP_NAME="EK Marketplace"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_BASE_URL=http://localhost:4000/api/v1

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
POSTGRES_USER=ekuser
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=ekmarketplace
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ekuser:change-me-in-production@localhost:5432/ekmarketplace

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# =============================================================================
# AUTH (NextAuth.js)
# =============================================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# JWT (API)
# =============================================================================
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# =============================================================================
# EMAIL (Resend or SMTP)
# =============================================================================
# Provider: resend | smtp
EMAIL_PROVIDER=resend

# Resend
RESEND_API_KEY=re_your_key_here
EMAIL_FROM="EK Marketplace <no-reply@koldmarket.co.uk>"
EMAIL_REPLY_TO=support@koldmarket.co.uk

# SMTP (alternative)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# =============================================================================
# STRIPE (Payments)
# =============================================================================
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_PRICE_SELLER_PLUS=price_seller_plus_id
STRIPE_PRICE_TRADER_PRO=price_trader_pro_id
STRIPE_PRICE_DEALER_BUSINESS=price_dealer_business_id

# Boost product IDs
STRIPE_PRODUCT_BUMP_UP=prod_bump_up_id
STRIPE_PRODUCT_FEATURED=prod_featured_id
STRIPE_PRODUCT_URGENT=prod_urgent_id
STRIPE_PRODUCT_SPOTLIGHT=prod_spotlight_id

# =============================================================================
# FILE UPLOADS
# =============================================================================
# Max file size in bytes (5MB)
MAX_FILE_SIZE=5242880
# Max images per listing
MAX_IMAGES_PER_LISTING=10
# Storage provider: local | s3 | cloudflare
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# AWS S3 (if STORAGE_PROVIDER=s3)
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Cloudflare R2 (if STORAGE_PROVIDER=cloudflare)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=

# =============================================================================
# AI (Phase 3+)
# =============================================================================
# Provider: openai | anthropic | ollama
AI_PROVIDER=openai
AI_ENABLED=false

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Ollama (local dev)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# AI rate limits
AI_MAX_CALLS_PER_USER_PER_DAY=50
AI_MAX_CALLS_PER_ENDPOINT_PER_MINUTE=20

# =============================================================================
# SEARCH (Phase 3+)
# =============================================================================
# Provider: postgres | elasticsearch
SEARCH_PROVIDER=postgres
ELASTICSEARCH_URL=http://localhost:9200

# =============================================================================
# LOGGING
# =============================================================================
# Log level: error | warn | info | debug
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_AUTH_REQUESTS=10

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_AI_SEARCH=false
FEATURE_AI_LISTING_ASSIST=false
FEATURE_AI_MODERATION=false
FEATURE_PAYMENTS=false
FEATURE_BUSINESS_ACCOUNTS=false
FEATURE_REVIEWS=false
FEATURE_MESSAGING=false

# =============================================================================
# ADMIN
# =============================================================================
ADMIN_EMAIL=admin@koldmarket.co.uk
ADMIN_SEED_PASSWORD=change-me-in-production

# =============================================================================
# MONITORING (optional)
# =============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
