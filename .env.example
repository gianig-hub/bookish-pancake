# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NODE_ENV=development
APP_NAME="EK Marketplace"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ──────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://ekuser:ekpassword@localhost:5432/ekmarketplace
POSTGRES_USER=ekuser
POSTGRES_PASSWORD=ekpassword
POSTGRES_DB=ekmarketplace
POSTGRES_PORT=5432

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ──────────────────────────────────────────────
# Authentication (NextAuth)
# ──────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-to-a-long-random-secret-in-production
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=change-me-to-a-long-random-jwt-secret

# ──────────────────────────────────────────────
# API Configuration
# ──────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ──────────────────────────────────────────────
# File Uploads
# ──────────────────────────────────────────────
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# Phase 2: Enable when adding Cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ──────────────────────────────────────────────
# Email (Phase 2)
# ──────────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@koldmarket.co.uk

# ──────────────────────────────────────────────
# Payments / Stripe (Phase 2)
# ──────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# ──────────────────────────────────────────────
# AI Services (Phase 3)
# ──────────────────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
LOG_LEVEL=debug
