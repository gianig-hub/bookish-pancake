# ============================================================
# EK Marketplace – Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# ─── Application URLs ────────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
WORKER_URL=http://localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── API Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database (PostgreSQL) ───────────────────────────────────
DATABASE_URL=postgresql://ekuser:ekpassword@localhost:5432/ekmarketplace
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ekmarketplace
DB_USER=ekuser
DB_PASSWORD=ekpassword

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ─── Auth / Session ──────────────────────────────────────────
# TODO: generate a strong secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-strong-random-secret
JWT_SECRET=replace-with-a-strong-random-secret
SESSION_COOKIE_NAME=ek_session

# ─── Email (Transactional) ───────────────────────────────────
# TODO: replace with real SMTP or SES/Resend credentials
EMAIL_FROM=noreply@example.co.uk
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user@example.com
SMTP_PASSWORD=smtp-password

# ─── File Storage ────────────────────────────────────────────
# TODO: add Cloudflare R2 or S3 credentials
STORAGE_PROVIDER=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-2
# AWS_S3_BUCKET=ek-marketplace-uploads
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=ek-marketplace-uploads
# R2_PUBLIC_URL=https://cdn.example.co.uk

# ─── Payments (Stripe) ───────────────────────────────────────
# TODO: add real Stripe keys when payments are implemented
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── AI / OpenAI ─────────────────────────────────────────────
# TODO: add real API key for Seller Copilot, AI search, moderation
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# AI_ENABLED=false

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
# SENTRY_DSN=https://...

# ─── Feature Flags ───────────────────────────────────────────
# Set to 'true' to enable features in development
FEATURE_AI_LISTING_ASSIST=false
FEATURE_PHOTO_UPLOAD=false
FEATURE_SUBSCRIPTIONS=false
FEATURE_BOOSTS=false

# ─── Moderation ──────────────────────────────────────────────
MODERATION_AUTO_APPROVE=true
# MODERATION_WEBHOOK_URL=
