# =============================================================================
# EK Marketplace — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME="EK Marketplace"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://ekmarket:ekmarket_dev@localhost:5432/ekmarket_dev
POSTGRES_USER=ekmarket
POSTGRES_PASSWORD=ekmarket_dev
POSTGRES_DB=ekmarket_dev
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis (Cache & Queues)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_generated_secret
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email (Transactional)
# -----------------------------------------------------------------------------
# Supported: smtp, sendgrid, resend
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@ekmarketplace.co.uk

# SendGrid (production)
SENDGRID_API_KEY=

# Resend (alternative)
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
# local | s3
STORAGE_PROVIDER=local
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE_MB=10

# AWS S3 (production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=eu-west-2

# -----------------------------------------------------------------------------
# AI Services
# -----------------------------------------------------------------------------
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000

# AI feature flags
AI_LISTING_ASSIST_ENABLED=true
AI_SEARCH_ENABLED=false
AI_MODERATION_ENABLED=false

# -----------------------------------------------------------------------------
# API Keys & Secrets
# -----------------------------------------------------------------------------
# Internal API secret (for service-to-service auth)
INTERNAL_API_SECRET=replace_with_generated_secret

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
# Levels: error, warn, info, http, debug

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_WANTED_ADS=false
FEATURE_BUSINESS_DIRECTORY=false
FEATURE_REVIEWS=false
FEATURE_SUBSCRIPTIONS=false

# -----------------------------------------------------------------------------
# Monitoring (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
