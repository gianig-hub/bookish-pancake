# ============================================================================
# EK MARKETPLACE - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env.local for local development
# Copy to .env.production for VPS deployment (never commit to Git)
# Fill in all values for your environment
# For development, the placeholder values below will work
# For production, replace with real values (API keys, credentials, etc)
# ============================================================================

# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================
# Core settings that define which app environment this is
# Controls logging verbosity, error handling, and feature availability
NODE_ENV=development
APP_URL=http://localhost:3000
APP_URL_ADMIN=http://admin.localhost:3000
API_URL=http://localhost:4000
API_INTERNAL_URL=http://api:4000
NEXTAUTH_URL=http://localhost:3000
DEBUG_MODE=true

# ============================================================================
# API CONFIGURATION
# ============================================================================
# Settings for the Express backend API server
# Controls port, rate limiting, CORS, and timeouts
API_PORT=4000
API_HOST=0.0.0.0
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW_MS=60000
CORS_ORIGINS=http://localhost:3000,http://admin.localhost:3000
API_TIMEOUT_MS=30000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL database connection settings
# For local dev, these values work with docker-compose
# For production, use strong passwords and secure connection
DATABASE_URL=postgresql://ekuser:ekpassword@db:5432/ekmarket
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=ekmarket
DATABASE_USER=ekuser
DATABASE_PASSWORD=ekpassword
DATABASE_SSL_MODE=disable

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Redis cache and job queue settings
# Used for caching, session storage, and background jobs
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_NAMESPACE=ekmarket:

# ============================================================================
# AUTHENTICATION & SESSION
# ============================================================================
# NextAuth and session configuration
# NEXTAUTH_SECRET: Generate with: openssl rand -base64 32
# Must be different for dev and production
NEXTAUTH_SECRET=your_random_secret_key_here_CHANGE_IN_PRODUCTION
SESSION_MAX_AGE=2592000
JWT_SECRET=your_jwt_secret_key_here_CHANGE_IN_PRODUCTION
PASSWORD_HASH_ROUNDS=10
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_SPECIAL_CHARS=true
SESSION_STORE=database

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
# Email service provider settings
# Used for signup confirmation, password reset, notifications
# Providers: sendgrid, aws_ses, mailgun, smtp
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=sg_test_your_sendgrid_api_key_here
EMAIL_FROM_ADDRESS=noreply@ekmarketplace.co.uk
EMAIL_FROM_NAME=EK Marketplace
EMAIL_REPLY_TO=support@ekmarketplace.co.uk

# ============================================================================
# FILE STORAGE CONFIGURATION
# ============================================================================
# File upload settings (local and cloud storage)
# For local dev: uses public/uploads/
# For production: switch to S3 for scalability
UPLOAD_DIR=public/uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,webp,gif
S3_BUCKET=ekmarket-uploads
S3_REGION=eu-west-2
S3_ACCESS_KEY_ID=your_aws_access_key_id_here

# ============================================================================
# PAYMENT PROCESSING
# ============================================================================
# Stripe payment configuration
# Used for seller listing boosts, featured placement, commissions
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here
CURRENCY_CODE=GBP
PAYMENT_MIN_AMOUNT=100

# ============================================================================
# AI & LANGUAGE MODELS
# ============================================================================
# AI service configuration (OpenAI, Anthropic, etc)
# Used for search ranking, moderation, seller copilot, recommendations
# Get keys from: https://platform.openai.com/account/api-keys
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4
AI_TIMEOUT_MS=30000
AI_MAX_RETRIES=3
AI_ENABLE_LOGGING=true

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
# Logging configuration and error tracking
# Used for debugging, monitoring production issues, compliance auditing
LOG_LEVEL=info
SENTRY_DSN=https://your-sentry-dsn-here
SENTRY_ENVIRONMENT=development
ENABLE_AUDIT_LOG=true
AUDIT_LOG_RETENTION_DAYS=90
ANALYTICS_ENABLED=true

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable features in development and testing
# Allows rolling out features gradually (Phase 2 -> Phase 3 -> etc)
# Use false for Phase 1 (MVP), enable in later phases
FEATURE_AI_SEARCH_RANKING=false
FEATURE_AI_MODERATION=false
FEATURE_AI_RECOMMENDATIONS=false
FEATURE_PAYMENTS_ENABLED=true
FEATURE_SELLER_COPILOT=false
FEATURE_BUSINESS_COPILOT=false
BETA_FEATURES_ENABLED=false
ADMIN_BYPASS_RATE_LIMIT=false

# ============================================================================
# MODERATION SETTINGS
# ============================================================================
# AI-assisted content moderation thresholds
# Determines spam detection, auto-approval, and manual review requirements
MODERATION_SPAM_THRESHOLD=0.7
MODERATION_AUTO_APPROVE_THRESHOLD=0.2
MODERATION_REVIEW_QUEUE_SIZE=100
MODERATION_DUPLICATE_CHECK_ENABLED=true
MODERATION_PRICE_ANOMALY_THRESHOLD=0.5
