# ============================================================================
# EK MARKETPLACE - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to:
#   .env.local         (for local development)
#   .env.production    (for VPS deployment - NEVER commit to Git)
#
# Fill in all values appropriate for your environment.
# For production, use real API keys and secrets.
# For development, these placeholder values work fine.
#
# SECURITY: Never commit .env files with real secrets to Git.
# Add to .gitignore: .env, .env.local, .env.production
# ============================================================================

# ============================================================================
# 1. APPLICATION ENVIRONMENT
# ============================================================================

# Application environment type
NODE_ENV=development

# Main marketplace website URL
APP_URL=http://localhost:3000

# Admin dashboard URL
APP_URL_ADMIN=http://admin.localhost:3000

# Backend API URL (public)
API_URL=http://localhost:4000

# Backend API URL (internal, for Docker)
API_INTERNAL_URL=http://api:4000

# NextAuth main URL (must match APP_URL)
NEXTAUTH_URL=http://localhost:3000

# Debug mode (verbose logging)
DEBUG_MODE=true

# ============================================================================
# 2. API CONFIGURATION
# ============================================================================

# Port API listens on
API_PORT=4000

# Host API binds to (0.0.0.0 for Docker)
API_HOST=0.0.0.0

# Rate limiting: max requests per window
API_RATE_LIMIT_REQUESTS=100

# Rate limiting: time window in milliseconds
API_RATE_LIMIT_WINDOW_MS=60000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://admin.localhost:3000

# API request timeout in milliseconds
API_TIMEOUT_MS=30000

# ============================================================================
# 3. DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection string (use for automatic setup)
DATABASE_URL=postgresql://ekuser:ekpassword@db:5432/ekmarket

# Database host
DATABASE_HOST=db

# Database port
DATABASE_PORT=5432

# Database name
DATABASE_NAME=ekmarket

# Database user
DATABASE_USER=ekuser

# Database password (change in production!)
DATABASE_PASSWORD=ekpassword

# SSL mode: disable (dev), require (production)
DATABASE_SSL_MODE=disable

# ============================================================================
# 4. REDIS CONFIGURATION
# ============================================================================

# Redis connection string
REDIS_URL=redis://redis:6379/0

# Redis host
REDIS_HOST=redis

# Redis port
REDIS_PORT=6379

# Redis password (optional)
REDIS_PASSWORD=

# Key namespace prefix
REDIS_NAMESPACE=ekmarket:

# ============================================================================
# 5. AUTHENTICATION & SESSION
# ============================================================================

# NextAuth secret (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=your_random_32_byte_secret_key_here_CHANGE_IN_PRODUCTION

# Session timeout in seconds (30 days)
SESSION_MAX_AGE=2592000

# JWT secret for token signing
JWT_SECRET=your_jwt_secret_key_here_CHANGE_IN_PRODUCTION

# Password hashing rounds (higher = slower but safer)
PASSWORD_HASH_ROUNDS=10

# Minimum password length
PASSWORD_MIN_LENGTH=8

# Require special characters in password
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# Where sessions are stored: database or memory
SESSION_STORE=database

# ============================================================================
# 6. EMAIL CONFIGURATION
# ============================================================================

# Email provider: sendgrid, aws_ses, mailgun, or smtp
EMAIL_PROVIDER=sendgrid

# API key for email provider (SendGrid format)
EMAIL_API_KEY=sg_test_your_sendgrid_api_key_here

# From address for all emails
EMAIL_FROM_ADDRESS=noreply@ekmarketplace.co.uk

# Display name in email From field
EMAIL_FROM_NAME=EK Marketplace

# Reply-to address for customer inquiries
EMAIL_REPLY_TO=support@ekmarketplace.co.uk

# ============================================================================
# 7. FILE STORAGE CONFIGURATION
# ============================================================================

# Local upload directory (for development)
UPLOAD_DIR=public/uploads

# Maximum file size in bytes (5MB = 5242880)
MAX_FILE_SIZE=5242880

# Allowed file types (comma-separated, no dots)
ALLOWED_FILE_TYPES=jpg,jpeg,png,webp,gif

# AWS S3 bucket name (for production)
S3_BUCKET=ekmarket-uploads

# AWS region for S3
S3_REGION=eu-west-2

# AWS access key ID (for S3 uploads)
S3_ACCESS_KEY_ID=your_aws_access_key_id_here

# ============================================================================
# 8. PAYMENT PROCESSING
# ============================================================================

# Stripe public key (publishable key)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# Stripe secret key (keep this SECRET!)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe webhook secret for payment events
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here

# Currency code (GBP for UK)
CURRENCY_CODE=GBP

# Minimum payment amount in pence (£1.00)
PAYMENT_MIN_AMOUNT=100

# ============================================================================
# 9. AI & LANGUAGE MODELS
# ============================================================================

# AI provider: openai, anthropic, or local
AI_PROVIDER=openai

# OpenAI API key (starts with sk-)
OPENAI_API_KEY=sk-your_openai_api_key_here

# OpenAI model to use: gpt-4, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4

# AI request timeout in milliseconds
AI_TIMEOUT_MS=30000

# Number of retries for AI requests
AI_MAX_RETRIES=3

# Enable logging of all AI requests (for debugging)
AI_ENABLE_LOGGING=true

# ============================================================================
# 10. LOGGING & MONITORING
# ============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Sentry error tracking DSN (optional)
SENTRY_DSN=https://your-sentry-dsn-here

# Sentry environment label
SENTRY_ENVIRONMENT=development

# Enable audit logging for compliance
ENABLE_AUDIT_LOG=true

# Days to retain audit logs (90 days standard)
AUDIT_LOG_RETENTION_DAYS=90

# Enable analytics collection
ANALYTICS_ENABLED=true

# ============================================================================
# 11. FEATURE FLAGS
# ============================================================================

# AI search ranking (Phase 3+)
FEATURE_AI_SEARCH_RANKING=false

# AI moderation scoring (Phase 3+)
FEATURE_AI_MODERATION=false

# AI recommendations (Phase 3+)
FEATURE_AI_RECOMMENDATIONS=false

# Enable payment processing (Phase 2+)
FEATURE_PAYMENTS_ENABLED=true

# Seller AI copilot (Phase 3+)
FEATURE_SELLER_COPILOT=false

# Business AI copilot (Phase 3+)
FEATURE_BUSINESS_COPILOT=false

# Beta features for testing
BETA_FEATURES_ENABLED=false

# Bypass rate limiting (admin testing only)
ADMIN_BYPASS_RATE_LIMIT=false

# ============================================================================
# 12. MODERATION SETTINGS
# ============================================================================

# Spam detection confidence threshold (0.0-1.0)
MODERATION_SPAM_THRESHOLD=0.7

# Auto-approve listings below this score (0.0-1.0)
MODERATION_AUTO_APPROVE_THRESHOLD=0.2

# Maximum size of manual review queue
MODERATION_REVIEW_QUEUE_SIZE=100

# Enable duplicate listing detection
MODERATION_DUPLICATE_CHECK_ENABLED=true

# Price anomaly threshold (0.5 = 50% deviation from market)
MODERATION_PRICE_ANOMALY_THRESHOLD=0.5
