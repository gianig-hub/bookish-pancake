# ==============================================================================
# KoldMarket — Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=KoldMarket
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ------------------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=koldmarket
POSTGRES_USER=koldmarket
POSTGRES_PASSWORD=changeme_in_production

# Full connection string (used by apps/api and apps/worker)
DATABASE_URL=postgresql://koldmarket:changeme_in_production@postgres:5432/koldmarket

# ------------------------------------------------------------------------------
# Cache & Queue (Redis)
# ------------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------
# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=changeme_generate_a_real_secret
NEXTAUTH_URL=http://localhost:3000

# JWT
JWT_SECRET=changeme_generate_a_real_secret
JWT_EXPIRY=7d

# ------------------------------------------------------------------------------
# OpenAI (AI features)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_PREMIUM_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ------------------------------------------------------------------------------
# Object Storage (images/files)
# Cloudflare R2 (S3-compatible) is recommended — cheap and fast
# ------------------------------------------------------------------------------
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_BUCKET=koldmarket-uploads
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_URL=https://cdn.koldmarket.co.uk

# Max file upload size in bytes (default 5MB)
MAX_FILE_SIZE=5242880

# ------------------------------------------------------------------------------
# Email (Transactional)
# Resend is recommended for transactional email
# ------------------------------------------------------------------------------
EMAIL_FROM=noreply@koldmarket.co.uk
EMAIL_FROM_NAME=KoldMarket

RESEND_API_KEY=re_...

# Fallback SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ------------------------------------------------------------------------------
# Payments (Stripe)
# ------------------------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Plan price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_SELLER_PLUS=price_...
STRIPE_PRICE_TRADER_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# ------------------------------------------------------------------------------
# Monitoring & Logging (optional, add when ready)
# ------------------------------------------------------------------------------
# Sentry for error tracking
SENTRY_DSN=

# Logflare or similar for structured logs
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Moderation & Trust (optional, add when ready)
# ------------------------------------------------------------------------------
# Recaptcha for forms
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ------------------------------------------------------------------------------
# SEO & Analytics (optional, add when ready)
# ------------------------------------------------------------------------------
GOOGLE_ANALYTICS_ID=G-...
GOOGLE_SEARCH_CONSOLE_VERIFICATION=

# ------------------------------------------------------------------------------
# Feature Flags (optional)
# ------------------------------------------------------------------------------
ENABLE_AI_LISTING_WRITER=true
ENABLE_AI_SEARCH=false
ENABLE_SUBSCRIPTIONS=false
