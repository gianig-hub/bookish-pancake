# Database - SQLite for local dev, PostgreSQL for production
DATABASE_URL="file:./dev.db"
# For PostgreSQL production: DATABASE_URL="postgresql://user:password@localhost:5432/ekmarket"

# NextAuth - generate a strong secret for production
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-min-32-chars-replace-in-production"

# Image Upload
UPLOAD_DIR="public/uploads"
MAX_FILE_SIZE="5242880"

# Environment
NODE_ENV="development"
