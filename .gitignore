# =============================================================================
# EK Marketplace — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Environment files (NEVER commit secrets)
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
*.env

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
dist/
build/
.next/
.turbo/
out/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
prisma/migrations/dev.db

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
*.iml
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Uploads (local dev storage)
# -----------------------------------------------------------------------------
public/uploads/*
!public/uploads/.gitkeep

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
*.dockerignore.local

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.pem
.vercel
.netlify
*.tgz
