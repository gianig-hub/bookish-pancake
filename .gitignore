# EK Marketplace – root .gitignore

# ─── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build outputs ────────────────────────────────────────────
dist/
build/
out/
.next/
*.tsbuildinfo

# ─── Environment ─────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production

# ─── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS / Editor ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
.vscode/settings.json
.idea/

# ─── Docker ───────────────────────────────────────────────────
.dockerignore

# ─── Testing & coverage ───────────────────────────────────────
coverage/
.nyc_output/
junit.xml

# ─── Misc ─────────────────────────────────────────────────────
*.tgz
.cache/
tmp/
