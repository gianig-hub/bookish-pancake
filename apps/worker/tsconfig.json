{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@ek/types": ["../../packages/types/src"],
      "@ek/config": ["../../packages/config/src"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
