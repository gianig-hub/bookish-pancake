{
  "name": "ek-marketplace",
  "version": "0.1.0",
  "private": true,
  "description": "AI-first UK vertical marketplace for AC, refrigeration, cold rooms, and related equipment and services",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "echo \"Run 'docker-compose up' to start all services locally\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
